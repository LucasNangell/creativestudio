# Ambiente
NODE_ENV=production
PORT=3000

# URL de conexão do Prisma (codifique @ na senha como %40)
# Exemplo Hostinger: mysql://usuario:Senha%40123@localhost:3306/nome_do_banco?charset=utf8mb4
DATABASE_URL="mysql://USUARIO:SENHA_CODIFICADA@localhost:3306/NOME_DO_BANCO?charset=utf8mb4"

# Parâmetros brutos (opcionais — usados por scripts locais)
MYSQL_HOST="localhost"
MYSQL_PORT="3306"
MYSQL_USER="USUARIO"
MYSQL_PASSWORD="SENHA"
MYSQL_DATABASE="NOME_DO_BANCO"

# URL pública do site (SEO, sitemap, links absolutos) — OBRIGATÓRIO em produção
NEXT_PUBLIC_SITE_URL="https://nangellcreativestudio.online"

# WhatsApp (somente dígitos, com DDI)
NEXT_PUBLIC_WHATSAPP_NUMBER="5561999999999"

# Analytics (opcionais)
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_GA4_ID=""

# Segredo para assinar cookies de sessão admin (mín. 32 caracteres em produção)
ADMIN_SESSION_SECRET="altere-este-segredo-em-producao-com-32-chars-min"

# Credenciais bootstrap do admin (usadas se o banco falhar ou usuário não existir)
# Devem coincidir com o seed ou ser alteradas após o primeiro login
ADMIN_BOOTSTRAP_EMAIL="admin@nangell.com.br"
ADMIN_BOOTSTRAP_PASSWORD="NangellAdmin@2026"
